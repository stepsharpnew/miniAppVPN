# ── Telegram Bot ─────────────────────────────────────
# Для preprod скопируйте этот же файл как .env.preprod и измените:
#   BOT_TOKEN  → токен тестового бота из BotFather
#   WEBAPP_URL → https://test.memeinternet.site
#   TELEGRAM_OUTBOUND_ALLOWLIST → Telegram/chat IDs, которым тестовый бот может писать
# Остальные ключи (БД, YooKassa, VPN API) общие с prod — preprod это полный аналог,
# но docker-compose принудительно включает APP_ENV=preprod, TELEGRAM_OUTBOUND_MODE=whitelist
# и SUBSCRIPTION_REMINDERS_AUTORUN=false, чтобы тестовый бот не писал реальным пользователям.
BOT_TOKEN=
ADMIN_CHAT_ID_BUY=
ADMIN_CHAT_ID_SUPPORT=https://t.me/...
WEBAPP_URL=https://app....
REQUIRED_CHANNEL_USERNAME=@Meme
APP_ENV=production
# live|whitelist|dry-run|off. В compose prod зафиксирован live, preprod — whitelist.
TELEGRAM_OUTBOUND_MODE=live
# Через запятую/пробел: user IDs и admin chat IDs, которым разрешены отправки в preprod.
TELEGRAM_OUTBOUND_ALLOWLIST=
# По умолчанию true только для APP_ENV=production. В compose preprod зафиксирован false.
SUBSCRIPTION_REMINDERS_AUTORUN=true

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
DATABASE_URL=

# ── Payment (YooKassa direct API — embedded widget) ──
MERCHANT_SHOP_ID=
MERCHANT_KEY=

# ── VPN API (for auto-provisioning after payment) ───
VPN_API_USER=
VPN_API_PASSWORD=
# Production: min 32 random chars each; NODE_ENV=production enforces this.
JWT_SECRET=
JWT_REFRESH_SECRET=
# Optional extra CORS origins (comma-separated), e.g. https://test.memeinternet.site
# CORS_EXTRA_ORIGINS=

# ── Website ──────────────────────────────────────────
# Mini App в Telegram: https://app.memeinternet.site (поддомен app в DNS).
WEB_SITE_URL=https:
