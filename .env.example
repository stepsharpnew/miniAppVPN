# ── Telegram Bot ─────────────────────────────────────
BOT_TOKEN=
ADMIN_CHAT_ID_BUY=
ADMIN_CHAT_ID_SUPPORT=
WEBAPP_URL=
# Обязательная подписка на канал в Mini App (getChatMember). Пусто = проверка отключена.
# Бот должен быть добавлен в канал как администратор.
REQUIRED_CHANNEL_USERNAME=

# ── PostgreSQL ───────────────────────────────────────
