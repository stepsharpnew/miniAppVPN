POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# ── AmneziaWG Backend ───────────────────────────────
NGINX_PORT=443
NGINX_USER=
NGINX_PASSWORD=
SSL_EMAIL=
SSL_DOMAIN=

# VPN server UDP ports
VPN_PORT_1=43457
VPN_PORT_2=45297
VPN_PORT_3=43724
VPN_PORT_4=47295

AMNEZIAWG_DEFAULT_PORT=51820
AMNEZIAWG_MTU=1420
AMNEZIAWG_SUBNET=10.0.0.0/24
AMNEZIAWG_DNS=8.8.8.8,1.1.1.1
AMNEZIAWG_AUTO_START=true

# ── Payment (YooKassa direct API — embedded widget) ──
