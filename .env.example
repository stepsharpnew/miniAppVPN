# ── VPN API (auto-provisioning after payment) ───────
VPN_BASE_URL=
VPN_API_USER=
VPN_API_PASSWORD=
VPN_SERVER_ID=

# ── Deploy (CI/CD) ──────────────────────────────────
SERVER_IP_ADDRESS=
SERVER_USERNAME=
