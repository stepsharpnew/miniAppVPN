# Copy this file to `.env` next to docker-compose.yml on each VPS and adjust.
# Compose reads .env automatically; values here override the `:-default` parts in docker-compose.yml.
# DO NOT commit your real .env — it stays on the VPS only.

# ─── Admin basic-auth (fronts the entire web UI + API) ──────────────────────
NGINX_USER=admin
NGINX_PASSWORD=changeme   # ← MUST change before going live; different per VPS

# ─── Let's Encrypt (optional but strongly recommended) ──────────────────────
# Both must be set together; certbot runs on container start.
SSL_EMAIL=
SSL_DOMAIN=               # e.g. de.memevpn.ru — domain points to *this* VPS

# ─── MemeVPN branding for the multi-server subscription ─────────────────────
MEMEVPN_BRAND=MemeVPN
MEMEVPN_SUB_UPDATE_HOURS=24   # how often HAPP/v2rayN refresh the subscription

# ─── Expiration ─────────────────────────────────────────────────────────────
# Days after expires_at to keep an expired client alive (so renewal is seamless).
# Set 0 to delete immediately (legacy behaviour).
CLIENT_DELETE_GRACE_DAYS=3

# ─── Federation (satellite mode) ────────────────────────────────────────────
# Hub VPS: leave SATELLITE_API_KEY empty. The hub doesn't need to expose the
# satellite API — it consumes it on remote VPSes.
#
# Satellite VPS: set to a long random string and put the SAME value into the
# hub's "Register satellite" form. Generate one with:
#   openssl rand -hex 32
SATELLITE_API_KEY=
